}

/* 图片消息样式 */
.message-image.data-v-394fd9eb {
	max-width: 400rpx;
	border-radius: 16rpx;
	margin-left: 16rpx;
}
.message-image.self-image.data-v-394fd9eb {
	margin-left: auto;
	margin-right: 16rpx;
}
.bottom-placeholder.data-v-394fd9eb {
	height: 24rpx;
}

/* 动画效果优化 */
@keyframes fadeInUp-394fd9eb {
0% {
		opacity: 0;
		transform: translateY(16rpx);
}
100% {
		opacity: 1;
		transform: translateY(0);
}
}
@keyframes pulse-394fd9eb {
0% {
		opacity: 0.8;
		transform: scale(0.98);
}
50% {
		opacity: 1;
		transform: scale(1);
}
100% {
		opacity: 0.8;
		transform: scale(0.98);
}
}

/* 滚动条样式 - 更精致的自定义样式 */
.data-v-394fd9eb::-webkit-scrollbar {
