	border-radius: 8rpx;
	margin: 10rpx 0;
}
.data-v-394fd9eb::-webkit-scrollbar-thumb {
	background: #d1d9e6;
	border-radius: 8rpx;
	-webkit-transition: all 0.2s ease;
	transition: all 0.2s ease;
}
.data-v-394fd9eb::-webkit-scrollbar-thumb:hover {
	background: #6a7ef8;
}

