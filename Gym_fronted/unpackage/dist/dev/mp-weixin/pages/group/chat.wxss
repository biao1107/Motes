
/* 基础容器样式 - 高级渐变+细腻质感 */
.container.data-v-394fd9eb {
	height: 100vh;
	display: flex;
	flex-direction: column;
	background: linear-gradient(135deg, #f5f7fa 0%, #e4eaf5 100%);
	position: relative;
}

/* 聊天容器样式 - 半透磨砂质感 */
.chat-container.data-v-394fd9eb {
	flex: 1;
	padding: 30rpx 24rpx;
	background: rgba(255, 255, 255, 0.2);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
	box-sizing: border-box;
	overflow: hidden;
	border-radius: 0;
}
.message-list.data-v-394fd9eb {
	padding-bottom: 30rpx;
}

