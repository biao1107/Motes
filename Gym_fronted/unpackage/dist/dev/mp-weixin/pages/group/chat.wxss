/* 发送按钮 - 圆形渐变+精致动效 */
.send-btn.data-v-394fd9eb {
	width: 72rpx;
	height: 72rpx;
	border-radius: 50%;
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	display: flex;
	align-items: center;
	justify-content: center;
	margin-left: 16rpx;
	padding: 0;
	border: none;
}
.send-btn.data-v-394fd9eb:not(.btn-disabled):hover {
