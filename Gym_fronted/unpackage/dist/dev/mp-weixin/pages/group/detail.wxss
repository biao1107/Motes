/* 弹窗样式优化 */
.popup-mask.data-v-858a584d {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background-color: rgba(0, 0, 0, 0.5);
	display: flex;
	justify-content: center;
	align-items: center;
	z-index: 999;
	-webkit-backdrop-filter: blur(4rpx);
	        backdrop-filter: blur(4rpx);
}
.popup.data-v-858a584d {
	width: 80%;
	background-color: #fff;
	border-radius: 24rpx;
	padding: 40rpx 30rpx;
	animation: popupSlideIn-858a584d 0.3s ease-out;
	z-index: 1002;
	box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}
.popup-large.data-v-858a584d {
	width: 90%;
