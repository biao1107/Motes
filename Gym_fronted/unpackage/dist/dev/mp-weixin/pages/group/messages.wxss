  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
  gap: 4rpx;
  padding: 6rpx;
  box-sizing: border-box;
  overflow: hidden;
}
.group-avatar-empty.data-v-1ffa5f7a {
  grid-column: 1 / -1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-cell.data-v-1ffa5f7a {
  position: relative;
  border-radius: 14rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.2);
}
.avatar-cell.count-1.data-v-1ffa5f7a {
  grid-column: 1 / -1;
  grid-row: 1 / -1;
}
.avatar-cell.count-2.data-v-1ffa5f7a:nth-child(1) {
  grid-column: 1;
  grid-row: 1 / -1;
}
.avatar-cell.count-2.data-v-1ffa5f7a:nth-child(2) {
  grid-column: 2;
  grid-row: 1 / -1;
}
.avatar-cell.count-3.data-v-1ffa5f7a:nth-child(1) {
  grid-column: 1;
  grid-row: 1 / -1;
}
.avatar-image.data-v-1ffa5f7a,
.avatar-fallback.data-v-1ffa5f7a {
