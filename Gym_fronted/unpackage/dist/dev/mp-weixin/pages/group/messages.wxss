
.message-page.data-v-1ffa5f7a {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(111, 146, 255, 0.16), transparent 24%),
    linear-gradient(180deg, #edf2ff 0%, #f5f7fc 42%, #f4f6fb 100%);
}
.hero-card.data-v-1ffa5f7a,
.section-card.data-v-1ffa5f7a,
.empty-card.data-v-1ffa5f7a {
  border-radius: 32rpx;
  overflow: hidden;
  box-sizing: border-box;
}
.hero-card.data-v-1ffa5f7a {
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(150deg, #1638b8 0%, #4c67f4 46%, #7790ff 100%);
  box-shadow: 0 20rpx 50rpx rgba(23, 56, 182, 0.22);
}
.hero-badge.data-v-1ffa5f7a {
  display: inline-flex;
  height: 42rpx;
  padding: 0 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  font-size: 20rpx;
  letter-spacing: 1rpx;
}
.hero-title.data-v-1ffa5f7a {
  display: block;
  margin-bottom: 12rpx;
  font-size: 40rpx;
  line-height: 1.28;
  font-weight: 700;
  color: #ffffff;
}
.hero-desc.data-v-1ffa5f7a {
  display: block;
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.82);
}
.section-card.data-v-1ffa5f7a,
.empty-card.data-v-1ffa5f7a {
  padding: 30rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 38rpx rgba(21, 35, 95, 0.08);
}
.invite-card.data-v-1ffa5f7a {
