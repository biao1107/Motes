
.container.data-v-3d21314d {
	background-color: #f5f5f5;
	min-height: 100vh;
}

/* 课程封面 */
.course-header.data-v-3d21314d {
	position: relative;
	height: 400rpx;
}
.course-cover.data-v-3d21314d {
	width: 100%;
	height: 100%;
}
.course-overlay.data-v-3d21314d {
	position: absolute;
	bottom: 0;
	left: 0;
	right: 0;
	background: linear-gradient(transparent, rgba(0,0,0,0.7));
	padding: 40rpx 30rpx 30rpx;
	color: white;
}
.course-title.data-v-3d21314d {
	font-size: 36rpx;
	font-weight: bold;
	display: block;
	margin-bottom: 10rpx;
}
.course-subtitle.data-v-3d21314d {
	font-size: 28rpx;
	opacity: 0.9;
}

/* 信息卡片 */
.info-card.data-v-3d21314d {
	background: white;
	margin: -30rpx 20rpx 20rpx;
	border-radius: 20rpx;
	padding: 30rpx;
	box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}
.info-grid.data-v-3d21314d {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 30rpx;
}
.info-item.data-v-3d21314d {
	text-align: center;
}
.info-label.data-v-3d21314d {
	font-size: 26rpx;
	color: #888;
	display: block;
	margin-bottom: 10rpx;
}
.info-value.data-v-3d21314d {
	font-size: 32rpx;
	font-weight: bold;
	color: #333;
}
.info-value.difficulty.data-v-3d21314d {
	padding: 8rpx 20rpx;
	border-radius: 30rpx;
	color: white;
}
.info-value.diff-beginner.data-v-3d21314d {
	background: #4caf50;
}
.info-value.diff-elementary.data-v-3d21314d {
	background: #ff9800;
}
.info-value.diff-intermediate.data-v-3d21314d {
	background: #f44336;
}
.info-value.diff-advanced.data-v-3d21314d {
	background: #9c27b0;
}

/* 内容区域 */
.content-section.data-v-3d21314d {
	background: white;
	margin: 0 20rpx 20rpx;
	border-radius: 20rpx;
	padding: 30rpx;
}
.section-header.data-v-3d21314d {
	margin-bottom: 30rpx;
}
.section-title.data-v-3d21314d {
	font-size: 32rpx;
	font-weight: bold;
	color: #333;
}
.content-list.data-v-3d21314d {
	display: flex;
	flex-direction: column;
	gap: 20rpx;
}
.content-item.data-v-3d21314d {
	display: flex;
	align-items: flex-start;
	gap: 20rpx;
	padding: 20rpx;
	background: #fafafa;
	border-radius: 15rpx;
}
.item-number.data-v-3d21314d {
	width: 50rpx;
	height: 50rpx;
	background: #667eea;
	color: white;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-weight: bold;
	flex-shrink: 0;
}
.item-content.data-v-3d21314d {
	flex: 1;
}
.item-title.data-v-3d21314d {
	font-size: 30rpx;
	font-weight: bold;
	color: #333;
	display: block;
	margin-bottom: 10rpx;
}
.item-details.data-v-3d21314d {
	display: flex;
	flex-wrap: wrap;
	gap: 15rpx;
}
.detail-item.data-v-3d21314d {
	font-size: 24rpx;
	color: #666;
	background: white;
	padding: 5rpx 15rpx;
	border-radius: 20rpx;
}

/* 视频区域 */
.video-section.data-v-3d21314d {
	background: white;
	margin: 0 20rpx 20rpx;
	border-radius: 20rpx;
	padding: 30rpx;
}
.video-container.data-v-3d21314d {
	background: #000;
	border-radius: 15rpx;
	overflow: hidden;
}
.course-video.data-v-3d21314d {
	width: 100%;
	height: 400rpx;
}

/* 视频错误提示 */
.video-error.data-v-3d21314d {
	padding: 40rpx 30rpx;
	text-align: center;
	background: #fff5f5;
	border-radius: 20rpx;
	margin: 20rpx;
}
.error-icon.data-v-3d21314d {
	font-size: 60rpx;
	display: block;
	margin-bottom: 20rpx;
}
.error-text.data-v-3d21314d {
	font-size: 28rpx;
	color: #f44336;
	display: block;
	margin-bottom: 30rpx;
}
.retry-btn.data-v-3d21314d {
	background: #f44336;
	color: white;
	border: none;
	padding: 15rpx 40rpx;
	border-radius: 50rpx;
	font-size: 26rpx;
}

/* 操作按钮 */
.action-section.data-v-3d21314d {
	padding: 20rpx;
	display: flex;
	justify-content: center;
}
.action-btn.data-v-3d21314d {
	width: 60%;
	height: 80rpx;
	border-radius: 40rpx;
	font-size: 30rpx;
	font-weight: bold;
	display: flex;
	align-items: center;
	justify-content: center;
}
.action-btn.secondary.data-v-3d21314d {
	background: white;
	color: #667eea;
	border: 2rpx solid #667eea;
}
