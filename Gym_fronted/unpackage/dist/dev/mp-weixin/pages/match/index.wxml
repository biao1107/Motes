<view wx:if="{{a}}" class="container data-v-edf061ca"><view class="match-header data-v-edf061ca"><text class="fitness-title data-v-edf061ca">智能匹配</text><text class="header-subtitle data-v-edf061ca">为您推荐最佳健身搭子</text></view><view wx:if="{{b}}" class="workout-card data-v-edf061ca"><view class="section-header data-v-edf061ca"><text class="fitness-subtitle data-v-edf061ca">为您推荐</text><text class="section-count data-v-edf061ca">{{c}}位搭子</text></view><view class="match-list data-v-edf061ca"><view wx:for="{{d}}" wx:for-item="item" wx:key="p" class="match-item data-v-edf061ca"><view class="match-avatar data-v-edf061ca"><image wx:if="{{item.a}}" src="{{item.b}}" class="avatar-image data-v-edf061ca" mode="aspectFill" binderror="{{item.c}}"/><text wx:else class="avatar-text data-v-edf061ca">{{item.d}}</text></view><view class="match-info data-v-edf061ca"><view class="match-basic data-v-edf061ca"><text class="match-name data-v-edf061ca">{{item.e}}</text><view class="match-score data-v-edf061ca"><text class="score-text data-v-edf061ca">{{item.f}}%</text><view class="score-bar data-v-edf061ca"><view class="score-fill data-v-edf061ca" style="{{'width:' + item.g}}"></view></view></view></view><view class="match-details data-v-edf061ca"><text wx:if="{{item.h}}" class="match-mode data-v-edf061ca">{{item.i}}</text><view class="match-tags data-v-edf061ca"><text wx:if="{{item.j}}" class="tag-item data-v-edf061ca">🎯 {{item.k}}</text><text wx:if="{{item.l}}" class="tag-item data-v-edf061ca">⏰ {{item.m}}</text><text wx:if="{{item.n}}" class="tag-item data-v-edf061ca">📍 {{item.o}}</text></view></view></view></view></view></view><view wx:else class="workout-card data-v-edf061ca"><view class="empty-state data-v-edf061ca"><view class="empty-icon data-v-edf061ca">🔍</view><text class="empty-text data-v-edf061ca">暂无匹配结果</text><text class="empty-subtext data-v-edf061ca">先完善个人档案，提高匹配精准度</text><button class="btn-fitness-primary data-v-edf061ca" bindtap="{{e}}"><text class="btn-text data-v-edf061ca">去完善档案</text></button></view></view><view class="bottom-actions data-v-edf061ca"><button class="btn-fitness-strength data-v-edf061ca" bindtap="{{f}}"><text class="btn-text data-v-edf061ca">刷新匹配</text></button></view></view><view wx:else class="loading-container data-v-edf061ca"><view class="loading-spinner data-v-edf061ca"></view><text class="loading-text data-v-edf061ca">正在匹配中...</text></view>