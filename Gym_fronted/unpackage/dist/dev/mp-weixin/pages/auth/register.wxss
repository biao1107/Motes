/* 动画：Logo光晕旋转 */
@keyframes logoGlow-4bb68961 {
0% {
    transform: rotate(0deg);
}
100% {
    transform: rotate(360deg);
}
}
/* 动画：按钮呼吸动效 */
@keyframes breath-4bb68961 {
0%, 100% {
    box-shadow: 0 10rpx 30rpx rgba(99, 120, 246, 0.35);
}
50% {
    box-shadow: 0 12rpx 40rpx rgba(99, 120, 246, 0.45);
}
}
