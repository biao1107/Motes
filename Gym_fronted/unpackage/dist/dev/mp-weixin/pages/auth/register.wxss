}

/* 双背景渐变装饰：左右各一个，提升层次感 */
.bg-decoration.data-v-4bb68961 {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.2;
  z-index: 1;
  background: linear-gradient(135deg, #6378f6 0%, #8F5FE8 100%);
}
.bg-left.data-v-4bb68961 {
  top: -100rpx;
  left: -100rpx;
}
.bg-right.data-v-4bb68961 {
  bottom: -100rpx;
  right: -100rpx;
}

/* 滚动容器：适配全面屏+键盘弹出 */
.main-scroll.data-v-4bb68961 {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  z-index: 2;
}

/* 内容容器：居中+内边距+适配不同屏幕 */
.content-wrapper.data-v-4bb68961 {
  width: 100%;
