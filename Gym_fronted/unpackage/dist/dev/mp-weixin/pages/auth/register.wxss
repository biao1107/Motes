
/* 页面全局样式：全屏+双渐变背景+抗锯齿 */
.register-page.data-v-4bb68961 {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #f8f9fb 0%, #eef1f8 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  position: relative;
  overflow: hidden;
