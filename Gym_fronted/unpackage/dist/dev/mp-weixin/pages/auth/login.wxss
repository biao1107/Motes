
/* 页面全局样式：全屏+渐变背景+抗锯齿，适配登录场景 */
.login-page.data-v-2cc9f8c3 {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #f8f9fb 0%, #eef1f8 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  position: relative;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 双背景装饰层：提升层次感和高级感 */
.bg-decoration.data-v-2cc9f8c3 {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #6378f6 0%, #8F5FE8 100%);
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.2;
  z-index: 1;
}
.bg-left.data-v-2cc9f8c3 {
  top: -100rpx;
  left: -100rpx;
}
.bg-right.data-v-2cc9f8c3 {
  top: -100rpx;
  right: -100rpx;
}

/* 滚动容器：适配键盘弹出+全面屏，禁止弹性回弹 */
.main-scroll.data-v-2cc9f8c3 {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  z-index: 2;
}

/* 内容容器：居中+内边距，适配不同屏幕 */
.content-wrapper.data-v-2cc9f8c3 {
  width: 100%;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 品牌区：视觉焦点，强化品牌认知 */
.brand-section.data-v-2cc9f8c3 {
  text-align: center;
  margin-bottom: 60rpx;
  width: 100%;
  padding-top: 20rpx;
}

/* Logo容器：玻璃拟态+光效+边框，提升精致度 */
.logo-container.data-v-2cc9f8c3 {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(99, 120, 246, 0.15);
  position: relative;
  z-index: 1;
}

/* Logo光效：渐变高光+旋转动效，提升质感 */
.logo-glow.data-v-2cc9f8c3 {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 196rpx;
  height: 196rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, rgba(99,120,246,0.2) 0%, rgba(143,95,232,0) 70%);
  z-index: -1;
  animation: logoGlow-2cc9f8c3 8s infinite linear;
}

/* Logo玻璃边框：细白边，提升精致度 */
.logo-border.data-v-2cc9f8c3 {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  z-index: -1;
}
.logo-img.data-v-2cc9f8c3 {
  width: 140rpx;
  height: 140rpx;
  z-index: 2;
}

/* 品牌标题：大字号+粗体+字间距，强化记忆 */
.brand-title.data-v-2cc9f8c3 {
  font-size: 48rpx;
  font-weight: 800;
  color: #1D2129;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 3rpx;
}

/* 品牌副标题：轻量级，场景化 */
.brand-subtitle.data-v-2cc9f8c3 {
  font-size: 28rpx;
  color: #7B8794;
  display: block;
  line-height: 1.6;
  padding: 0 20rpx;
}

/* 登录卡片：轻玻璃拟态+悬浮阴影+大圆角，核心操作区 */
.login-card.data-v-2cc9f8c3 {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.06), 0 2rpx 10rpx rgba(99, 120, 246, 0.04);
  -webkit-backdrop-filter: blur(15rpx);
          backdrop-filter: blur(15rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  margin-bottom: 40rpx;
  position: relative;
}

/* 登录方式切换：胶囊式设计，市场主流+过渡动画 */
.login-tabs.data-v-2cc9f8c3 {
  display: flex;
  background: #F9FAFB;
  border-radius: 50rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}
.tab-item.data-v-2cc9f8c3 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: 42rpx;
  font-size: 28rpx;
  color: #86909C;
  transition: all 0.25s ease-in-out;
}

/* 激活态：主色渐变+白色文字+阴影，视觉突出 */
.tab-item.active.data-v-2cc9f8c3 {
  background: linear-gradient(135deg, #6378f6 0%, #8F5FE8 100%);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 15rpx rgba(99, 120, 246, 0.35);
  transform: translateY(-2rpx);
}

/* 点击反馈：小程序专属 */
.tab-hover.data-v-2cc9f8c3 {
  opacity: 0.9 !important;
}
.tab-icon.data-v-2cc9f8c3 {
  font-size: 24rpx;
}

/* 输入组：统一间距+最后一个无下间距 */
.input-group.data-v-2cc9f8c3 {
  margin-bottom: 32rpx;
}
.input-group.data-v-2cc9f8c3:last-child {
  margin-bottom: 0;
}

/* 输入框容器：圆角+浅灰背景+聚焦态强化+过渡动画 */
.input-wrapper.data-v-2cc9f8c3 {
  display: flex;
  align-items: center;
  height: 100rpx;
  background: #F9FAFB;
  border-radius: 18rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.25s ease-in-out;
}

/* 聚焦态：主色边框+白色背景+轻阴影+微缩放，提升交互感知 */
.input-wrapper.focused.data-v-2cc9f8c3 {
  border-color: #6378f6;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(99, 120, 246, 0.1), 0 4rpx 12rpx rgba(99, 120, 246, 0.08);
  transform: translateY(-2rpx);
}

/* 手机号前缀：主色+粗体+分隔线，视觉区分 */
.input-prefix.data-v-2cc9f8c3 {
  font-size: 28rpx;
  color: #6378f6;
  font-weight: 600;
  padding-right: 20rpx;
  margin-right: 20rpx;
  border-right: 2rpx solid #F2F3F5;
  flex-shrink: 0;
}

/* 输入框：自适应宽度，统一样式 */
.input-field.data-v-2cc9f8c3 {
  flex: 1;
  font-size: 28rpx;
  color: #1D2129;
  background: transparent;
  height: 100%;
  font-weight: 500;
}

/* 占位符：低饱和灰色，提升可读性 */
.input-placeholder.data-v-2cc9f8c3 {
  color: #C9CDD4;
  font-size: 26rpx;
  font-weight: 400;
}

/* 输入框图标：浅灰色，弱化干扰 */
.input-icon.data-v-2cc9f8c3 {
  font-size: 32rpx;
  color: #BFC8D2;
  flex-shrink: 0;
}

/* 验证码行：flex布局，适配按钮 */
.verification-row.data-v-2cc9f8c3 {
  display: flex;
  gap: 20rpx;
  align-items: center;
}
.flex-1.data-v-2cc9f8c3 {
  flex: 1;
}

/* 验证码按钮：主色渐变+圆角+过渡，市场级设计 */
.code-btn.data-v-2cc9f8c3 {
  width: 200rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6378f6 0%, #8F5FE8 100%);
  border: none;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

/* 禁用态：灰色+降透，视觉区分 */
.code-btn.disabled.data-v-2cc9f8c3 {
  background: #F2F3F5;
  opacity: 0.7;
}
.code-btn-text.data-v-2cc9f8c3 {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}
.code-btn.disabled .code-btn-text.data-v-2cc9f8c3 {
  color: #86909C;
}

/* 登录主按钮：全宽+呼吸动效+箭头，视觉焦点 */
.login-primary-btn.data-v-2cc9f8c3 {
  width: 100%;
  height: 108rpx;
  background: linear-gradient(135deg, #6378f6 0%, #8F5FE8 100%);
  border: none;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 10rpx 30rpx rgba(99, 120, 246, 0.35);
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  animation: breath-2cc9f8c3 4s infinite ease-in-out;
  position: relative;
  overflow: hidden;
}

/* 呼吸动效：更柔和的阴影变化 */
@keyframes breath-2cc9f8c3 {
0%, 100% {
    box-shadow: 0 10rpx 30rpx rgba(99, 120, 246, 0.35);
}
50% {
    box-shadow: 0 12rpx 40rpx rgba(99, 120, 246, 0.45);
}
}

/* Logo光晕旋转动效 */
@keyframes logoGlow-2cc9f8c3 {
0% {
    transform: rotate(0deg);
}
100% {
    transform: rotate(360deg);
}
}
.login-btn-text.data-v-2cc9f8c3 {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* 按钮箭头：小字号+白色 */
.btn-arrow.data-v-2cc9f8c3 {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 快捷操作：居中，轻量化 */
.quick-actions.data-v-2cc9f8c3 {
  text-align: center;
}
.action-link.data-v-2cc9f8c3 {
  font-size: 26rpx;
  color: #6378f6;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
}

/* 协议区：底部轻量化，合规设计 */
.agreement-section.data-v-2cc9f8c3 {
  width: 100%;
  text-align: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  line-height: 1.8;
}
.agreement-text.data-v-2cc9f8c3 {
  font-size: 22rpx;
  color: #86909C;
}
.agreement-link.data-v-2cc9f8c3 {
  font-size: 22rpx;
  color: #6378f6;
  text-decoration: underline;
  margin: 0 6rpx;
}

/* 全局点击反馈：小程序专属+过渡动画 */
.btn-hover.data-v-2cc9f8c3 {
  transform: scale(0.97) !important;
  opacity: 0.95 !important;
  transition: all 0.15s ease !important;
}
.link-hover.data-v-2cc9f8c3 {
  opacity: 0.8 !important;
  background: rgba(99, 120, 246, 0.08) !important;
  transition: all 0.15s ease !important;
}
